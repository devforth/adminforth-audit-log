{
  "name": "@adminforth/audit-log",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Audit log plugin for AdminForth with CRUD diffs, actor tracking, and activity history",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/audit-log/",
  "repository": {
    "type": "git",
    "url": "https://github.com/devforth/adminforth-audit-log.git"
  },
  "bugs": {
    "url": "https://github.com/devforth/adminforth-audit-log/issues"
  },
  "author": "DevForth (https://devforth.io)",
  "keywords": [
    "adminforth",
    "audit-log",
    "change-tracking",
    "activity-history",
    "crud",
    "compliance",
    "forensics"
  ],
  "license": "MIT",
  "dependencies": {
    "dayjs": "^1.11.11"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "peerDependencies": {
    "adminforth": "^2.42.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/audit-log",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "adminforth": "^2.42.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  }
}
