{
  "compilerOptions": {
    "target": "es2016",
    "module": "node16",
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
  },
  "exclude": ["node_modules", "dist", "custom"],
}
